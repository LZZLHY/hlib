{
  "app": {
    /*
     * signingConfigs 不入库——避免证书路径与密码进入 git。
     * 本地构建时在 DevEco Studio 的 File > Project Structure > Signing Configs 配置，
     * IDE 会把签名信息写回本文件；提交时请勿带上 material 段。
     * CI / 命令行构建：通过环境变量注入并在构建前生成本地 build-profile。
     */
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "targetSdkVersion": "6.1.0(23)",
        "compatibleSdkVersion": "6.1.0(23)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "nativeCompiler": "BiSheng",
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug"
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}